# ===========================================
# Long Health — Production Environment
# ===========================================
# Copy this file and fill in your values.
# DO NOT commit the actual .env.production file.

# Server
NODE_ENV=production
PORT=3001

# Neon PostgreSQL
# Get from: https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/longhealth?sslmode=require

# Upstash Redis
# Get from: https://console.upstash.com → Redis → Details
REDIS_URL=rediss://default:xxx@apn1-xxx.upstash.io:6379

# JWT Authentication
# Generate with: openssl rand -base64 48
JWT_SECRET=<min-32-characters>
JWT_EXPIRY=7d

# Claude API
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxx

# AWS S3 (optional — leave empty for staging without PDF upload)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# CORS (set to your Render frontend URL)
CORS_ORIGIN=https://longhealth-web.onrender.com

# Logging
LOG_LEVEL=info

# ===========================================
# Frontend (set in Render dashboard as env var)
# ===========================================
# NEXT_PUBLIC_API_URL=https://longhealth-api.onrender.com/api/v1
