{
  "name": "@long-health/backend",
  "version": "1.0.0",
  "description": "Long Health backend API - blood report analysis and processing",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:up": "node-pg-migrate up --migrations-dir src/db/migrations --tsconfig tsconfig.json",
    "migrate:down": "node-pg-migrate down --migrations-dir src/db/migrations --tsconfig tsconfig.json",
    "migrate:create": "node-pg-migrate create --migrations-dir src/db/migrations --tsconfig tsconfig.json",
    "seed": "tsx src/db/seeds/run.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "pg": "^8.11.3",
    "node-pg-migrate": "^6.2.2",
    "ioredis": "^5.3.2",
    "bullmq": "^5.73.1",
    "jsonwebtoken": "^9.0.3",
    "bcryptjs": "^2.4.3",
    "@anthropic-ai/sdk": "^0.85.0",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/jest": "^29.5.11",
    "@types/multer": "^1.4.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
